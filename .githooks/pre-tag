#!/bin/bash
## Git pre-tag hook: auto-update file_manifest.txt before tagging.
## Place this file in .git/hooks/pre-tag or run: git config core.hooksPath .githooks
##
## It diffs the working tree against the last tag to find added/removed files
## in addons/gdsql/ and appends them to file_manifest.txt.

MANIFEST="addons/gdsql/tabs/plugin_updater/file_manifest.txt"
CUR_TAG="${1:-$(git describe --tags --dirty 2>/dev/null || echo 'dev')}"

# Find the previous tag
PREV_TAG=$(git tag --sort=-version:refname | grep -E '^v' | head -1)

if [ -z "$PREV_TAG" ]; then
	echo "No previous tag found, skipping manifest update."
	exit 0
fi

echo "Updating manifest: $PREV_TAG -> $CUR_TAG"

# New files
git diff --name-only --diff-filter=A "$PREV_TAG"...HEAD -- addons/gdsql/ | while read f; do
	echo "+,$CUR_TAG,$f" >> "$MANIFEST"
	echo "  + $f"
done

# Removed files
git diff --name-only --diff-filter=D "$PREV_TAG"...HEAD -- addons/gdsql/ | while read f; do
	echo "-,$CUR_TAG,$f" >> "$MANIFEST"
	echo "  - $f"
done

git add "$MANIFEST"
echo "Manifest updated."
