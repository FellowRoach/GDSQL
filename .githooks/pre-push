#!/bin/bash
## Git pre-push hook: auto-update file_manifest.txt before pushing a tag.
## Install: git config core.hooksPath .githooks
##
## Detects if a tag is being pushed, diffs against the last tag,
## and appends added/removed file entries to file_manifest.txt.
## If the manifest changed, the push is aborted so the user can
## commit the manifest update and push again.

MANIFEST="addons/gdsql/tabs/plugin_updater/file_manifest.txt"
CHANGED=0

# Read stdin to check if a tag is being pushed
while read local_ref local_sha remote_ref remote_sha; do
	if [[ "$local_ref" == refs/tags/v* ]]; then
		TAG="${local_ref#refs/tags/}"
		VER="${TAG#v}"

		PREV_TAG=$(git tag --sort=-version:refname | grep -E '^v' | sed -n '2p')

		if [ -n "$PREV_TAG" ]; then
			echo "Diffing $PREV_TAG → $TAG"

			grep -v "^[+-],$VER," "$MANIFEST" > "${MANIFEST}.tmp" 2>/dev/null && mv "${MANIFEST}.tmp" "$MANIFEST"

			while IFS= read -r f; do
				[ -n "$f" ] && echo "+,$VER,$f" >> "$MANIFEST"
			done < <(git diff --name-only --diff-filter=A "$PREV_TAG"...HEAD -- addons/gdsql/ | grep -v '\.import$\|\.translation$')
			while IFS= read -r f; do
				[ -n "$f" ] && echo "-,$VER,$f" >> "$MANIFEST"
			done < <(git diff --name-only --diff-filter=D "$PREV_TAG"...HEAD -- addons/gdsql/ | grep -v '\.import$\|\.translation$')
		else
			echo "No previous tag. Creating initial manifest."
			find addons/gdsql/ -type f \
				! -name '*.import' \
				! -name '*.translation' \
				| sort \
				| sed "s|^|+,$VER,|" > "$MANIFEST"
		fi

		git add "$MANIFEST"

		if ! git diff --cached --quiet "$MANIFEST"; then
			CHANGED=1
		fi
		break
	fi
done

if [ "$CHANGED" -eq 1 ]; then
	echo ""
	echo "=== file_manifest.txt updated and staged ==="
	echo "Commit it, then push again:"
	echo "  git commit -m \"Update file_manifest for $TAG\""
	echo "  git push origin $TAG"
	exit 1
fi

exit 0
